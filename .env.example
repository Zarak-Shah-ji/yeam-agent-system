# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/yeam_dev"
# Production: append ?sslmode=require
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/yeam_prod?sslmode=require"

# NextAuth v5
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-output"

# Production URL (required on Vercel — set to your deployment URL)
AUTH_URL="https://yeamagentsystem.vercel.app"
# Dev alias (also accepted):
# NEXTAUTH_URL="http://localhost:3000"

# GitHub OAuth — NextAuth v5 standard names (preferred)
AUTH_GITHUB_ID=your-github-app-client-id
AUTH_GITHUB_SECRET=your-github-app-client-secret
# Legacy aliases also accepted by the code:
# GITHUB_CLIENT_ID=...
# GITHUB_CLIENT_SECRET=...

# Google OAuth — NextAuth v5 standard names (preferred)
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret
# Legacy aliases also accepted by the code:
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...

# OAuth callback URLs to register in provider consoles:
#   GitHub:  https://yeamagentsystem.vercel.app/api/auth/callback/github
#   Google:  https://yeamagentsystem.vercel.app/api/auth/callback/google

# AI keys
ANTHROPIC_API_KEY="sk-ant-..."
GEMINI_API_KEY="AIza..."

NODE_ENV="development"
